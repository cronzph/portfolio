/* ============================================================
   BASE RESET & ROOT VARIABLES
   ============================================================ */
* { margin: 0; padding: 0; box-sizing: border-box; }

:root,
[data-theme="dark"] {
    --bg-primary:      #0a0a0a;
    --bg-secondary:    #111111;
    --bg-tertiary:     #1a1a1a;
    --text-primary:    #ffffff;
    --text-secondary:  #b0b0b0;
    --text-muted:      #707070;
    --accent-primary:  #6366f1;
    --accent-secondary:#8b5cf6;
    --border-color:    #2a2a2a;
    --shadow:          rgba(0,0,0,0.5);
    --gradient:        linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    --card-bg:         #1a1a1a;
    --card-border:     rgba(255,255,255,0.07);
    --highlight-text:  #f0f0f0;
    --highlight-sub:   rgba(255,255,255,0.5);
    --highlight-cat:   rgba(255,255,255,0.35);
}

[data-theme="light"] {
    --bg-primary:      #f5f5f7;
    --bg-secondary:    #ffffff;
    --bg-tertiary:     #eaeaee;
    --text-primary:    #111827;
    --text-secondary:  #4b5563;
    --text-muted:      #9ca3af;
    --accent-primary:  #4f46e5;
    --accent-secondary:#7c3aed;
    --border-color:    #d1d5db;
    --shadow:          rgba(0,0,0,0.08);
    --gradient:        linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    --card-bg:         #ffffff;
    --card-border:     rgba(0,0,0,0.08);
    --highlight-text:  #111827;
    --highlight-sub:   #6b7280;
    --highlight-cat:   #9ca3af;
}

/* ============================================================
   BODY & LAYOUT
   ============================================================ */
body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
    overflow-x: hidden;
    transition: background-color 0.3s ease, color 0.3s ease;
}

.container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
html { scroll-behavior: smooth; }

/* ============================================================
   THEME TOGGLE BUTTON
   ============================================================ */
.theme-toggle {
    position: fixed;
    top: 1.25rem;
    right: 1.5rem;
    z-index: 1100;
    width: 52px;
    height: 28px;
    border-radius: 999px;
    border: 2px solid var(--border-color);
    background: var(--bg-tertiary);
    cursor: pointer;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 2px 8px var(--shadow);
    padding: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
}

.theme-toggle:hover {
    box-shadow: 0 4px 16px rgba(99, 102, 241, 0.35);
    border-color: var(--accent-primary);
}

.theme-toggle::before {
    content: '';
    position: absolute;
    left: 3px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--gradient);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.3s ease;
    box-shadow: 0 1px 4px rgba(0,0,0,0.3);
}

[data-theme="light"] .theme-toggle::before {
    transform: translateX(22px);
}

/* Icon display */
.theme-toggle .sun,
.theme-toggle .moon {
    position: absolute;
    font-size: 0.7rem;
    line-height: 1;
    transition: opacity 0.25s ease;
    pointer-events: none;
}

.theme-toggle .sun  { right: 6px; }
.theme-toggle .moon { left: 6px; }

/* Dark mode: show moon, hide sun */
[data-theme="dark"]  .theme-toggle .sun  { opacity: 1; }
[data-theme="dark"]  .theme-toggle .moon { opacity: 0; }

/* Light mode: show sun, hide moon */
[data-theme="light"] .theme-toggle .sun  { opacity: 0; }
[data-theme="light"] .theme-toggle .moon { opacity: 1; }

/* ============================================================
   NAVBAR
   ============================================================ */
.navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    background: var(--bg-secondary);
    opacity: 0.97;
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
    padding: 1rem 0;
    z-index: 1000;
    transition: background 0.3s ease, border-color 0.3s ease;
}

.navbar .container { display: flex; justify-content: space-between; align-items: center; }

.nav-brand h2 {
    font-size: 1.5rem;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.nav-links { display: flex; gap: 2rem; }
.nav-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.3s;
    position: relative;
}
.nav-links a::after {
    content: "";
    position: absolute;
    bottom: -5px; left: 0;
    width: 0; height: 2px;
    background: var(--gradient);
    transition: width 0.3s;
}
.nav-links a:hover { color: var(--text-primary); }
.nav-links a:hover::after { width: 100%; }

/* ============================================================
   HERO
   ============================================================ */
.hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: radial-gradient(ellipse at center, rgba(99,102,241,0.08) 0%, transparent 70%);
    padding-top: 80px;
}

[data-theme="light"] .hero {
    background: radial-gradient(ellipse at center, rgba(79,70,229,0.06) 0%, transparent 70%);
}

.hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
        linear-gradient(90deg, transparent 49%, rgba(99,102,241,0.03) 50%, transparent 51%),
        linear-gradient(0deg,   transparent 49%, rgba(99,102,241,0.03) 50%, transparent 51%);
    background-size: 50px 50px;
    opacity: 0.3;
}

[data-theme="light"] .hero::before { opacity: 0.15; }

.hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
    animation: fadeInUp 1s ease;
}

.hero-text h1 {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-primary);
    line-height: 1.2;
}

.typing-container { display: flex; align-items: center; gap: 0.5rem; margin: 1.5rem 0; }

.im-a, .typing-text {
    font-size: 1.8rem;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 600;
}

.typing-text {
    min-width: 200px;
    animation: blink 0.7s step-end infinite;
}

@keyframes blink {
    0%, 100% { border-color: transparent; }
    50%       { border-color: var(--accent-primary); }
}

.hero-description {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 2rem;
    line-height: 1.8;
}

/* ============================================================
   BUTTONS
   ============================================================ */
.btn {
    display: inline-block;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
}

.btn-primary {
    background: var(--gradient);
    color: #fff;
    box-shadow: 0 4px 15px rgba(99,102,241,0.3);
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(99,102,241,0.4);
}

/* ============================================================
   HERO IMAGE
   ============================================================ */
.hero-image {
    position: relative;
    display: flex;
    justify-content: center;
}

.hero-image img {
    width: 100%;
    max-width: 400px;
    height: auto;
    border-radius: 12px;
    border: 2px solid var(--border-color);
    box-shadow: 0 8px 30px rgba(99,102,241,0.2);
    display: block;
    transition: box-shadow 0.3s ease, border-color 0.3s ease, filter 0.3s ease;
}

/* Light mode: soft white ring glow + diffused shadow to ease the dark photo into the light bg */
[data-theme="light"] .hero-image img {
    border-color: #c7d2fe;
    box-shadow:
        0 0 0 5px rgba(255,255,255,0.9),
        0 0 0 6px rgba(199,210,254,0.5),
        0 12px 40px rgba(0,0,0,0.1),
        0 4px 12px rgba(0,0,0,0.07);
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.08));
}

/* ============================================================
   SECTIONS
   ============================================================ */
section { padding: 6rem 0; position: relative; }

.section-title {
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 1rem;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.section-subtitle {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 3rem;
}

/* ============================================================
   PORTFOLIO / POST CARDS
   ============================================================ */
.portfolio-section { background: var(--bg-secondary); }

.portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
}

.post-card {
    background: var(--bg-tertiary);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border-color);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
}

.post-card::after {
    content: "👁️ View Details";
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: var(--gradient);
    color: #fff;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 2;
}

.post-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
}

[data-theme="light"] .post-card::before { background: rgba(0,0,0,0.45); }

.post-card:hover::before,
.post-card:hover::after { opacity: 1; }

.post-card:hover {
    transform: translateY(-8px);
    border-color: var(--accent-primary);
    box-shadow: 0 12px 32px rgba(99,102,241,0.25);
}

[data-theme="light"] .post-card:hover {
    box-shadow: 0 12px 32px rgba(79,70,229,0.18);
}

.post-banner {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--gradient);
    position: relative;
}

.post-banner img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.post-card:hover .post-banner img { transform: scale(1.08); }

.post-image { width: 100%; height: 100%; object-fit: cover; display: block; }

.no-image {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%; height: 100%;
    color: #fff;
    font-size: 1.125rem;
    font-weight: 500;
    opacity: 0.8;
}

.post-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-grow: 1;
    background: var(--bg-tertiary);
    transition: background 0.3s ease;
}

.post-category {
    display: inline-block;
    background: rgba(99,102,241,0.15);
    color: var(--accent-primary);
    padding: 0.375rem 0.875rem;
    border-radius: 8px;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 1px solid rgba(99,102,241,0.25);
    width: fit-content;
}

[data-theme="light"] .post-category {
    background: rgba(79,70,229,0.08);
    border-color: rgba(79,70,229,0.2);
}

.post-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.post-description {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.post-meta {
    color: var(--text-muted);
    font-size: 0.875rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border-color);
    margin-top: auto;
}

/* ============================================================
   VIEW ALL BUTTON
   ============================================================ */
.view-all-container {
    display: grid;
    place-items: center;
    margin-top: 3rem;
    padding-top: 2rem;
}

.view-all-container .btn {
    position: relative;
    padding: 1.25rem 3rem;
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    overflow: hidden;
    border: 2px solid transparent;
    background: var(--gradient);
    background-size: 200% 200%;
    animation: gradientShift 3s ease infinite;
}

.view-all-container .btn::before {
    content: "";
    position: absolute;
    top: 50%; left: 50%;
    width: 0; height: 0;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
}

.view-all-container .btn:hover::before { width: 300px; height: 300px; }
.view-all-container .btn:hover { transform: translateY(-4px) scale(1.02); box-shadow: 0 12px 40px rgba(99,102,241,0.4); }
.view-all-container .btn span { position: relative; z-index: 1; }

@keyframes gradientShift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

/* ============================================================
   PROJECT HIGHLIGHTS SECTION
   ============================================================ */
.highlights-section { padding: 6rem 0; background: var(--bg-primary); }

.highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
}

.highlight-card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    cursor: pointer;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 12px var(--shadow);
}

[data-theme="light"] .highlight-card {
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}

.highlight-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.18);
    border-color: var(--accent-color);
}

[data-theme="light"] .highlight-card:hover {
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
}

.highlight-card::before {
    content: '';
    display: block;
    height: 4px;
    width: 100%;
    background: var(--accent-color);
    flex-shrink: 0;
}

.highlight-thumb {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
}

.highlight-thumb-placeholder {
    width: 100%;
    aspect-ratio: 16/9;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    background: linear-gradient(135deg, rgba(99,102,241,0.05), rgba(139,92,246,0.1));
}

[data-theme="light"] .highlight-thumb-placeholder {
    background: linear-gradient(135deg, rgba(79,70,229,0.04), rgba(124,58,237,0.08));
}

.highlight-body {
    padding: 1.25rem 1.4rem 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--card-bg);
    transition: background 0.3s ease;
}

.highlight-category-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-color);
    /* fallback so it's always visible */
    opacity: 1;
}

.highlight-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--highlight-text) !important;
    margin: 0;
    line-height: 1.4;
    transition: color 0.3s ease;
}

.highlight-desc {
    font-size: 0.82rem;
    color: var(--highlight-sub) !important;
    line-height: 1.5;
    margin: 0;
    flex: 1;
    transition: color 0.3s ease;
}

/* Explicit overrides per theme to guarantee text visibility */
[data-theme="light"] .highlight-title { color: #111827 !important; }
[data-theme="light"] .highlight-desc  { color: #6b7280 !important; }
[data-theme="light"] .highlight-category-label { opacity: 0.9; }

[data-theme="dark"] .highlight-title { color: #f0f0f0 !important; }
[data-theme="dark"] .highlight-desc  { color: rgba(255,255,255,0.5) !important; }

.highlight-view-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--accent-color);
    text-decoration: none;
    transition: gap 0.2s ease;
}

.highlight-view-btn:hover { gap: 0.7rem; }

.highlight-view-btn svg {
    width: 14px; height: 14px;
    stroke: currentColor; fill: none;
    stroke-width: 2.5;
    stroke-linecap: round; stroke-linejoin: round;
    flex-shrink: 0;
}

.highlights-loading {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem;
    gap: 1rem;
    color: var(--text-muted);
}

/* Accent colors per category */
.highlight-card[data-cat="Web Development"]    { --accent-color: #4f9eff; }
.highlight-card[data-cat="Mobile Development"] { --accent-color: #a78bfa; }
.highlight-card[data-cat="Arduino / IoT"]      { --accent-color: #34d399; }
.highlight-card[data-cat="Networking"]         { --accent-color: #f59e0b; }
.highlight-card[data-cat="Cyber Security"]     { --accent-color: #f87171; }
.highlight-card[data-cat="IT Support"]         { --accent-color: #60a5fa; }
.highlight-card[data-cat="AI Automation"]      { --accent-color: #e879f9; }
.highlight-card[data-cat="Game Development"]   { --accent-color: #fb923c; }
.highlight-card[data-cat="Smart Systems"]      { --accent-color: #2dd4bf; }

/* ============================================================
   ABOUT SECTION
   ============================================================ */
.about-section { background: var(--bg-secondary); }

.about-content { max-width: 800px; margin: 0 auto; text-align: center; }
.about-content p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.8;
}

.skills { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }

.skill-tag {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    padding: 0.75rem 1.5rem;
    border-radius: 25px;
    font-size: 0.95rem;
    color: var(--text-secondary);
    transition: all 0.3s;
}

.skill-tag:hover {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
    transform: translateY(-2px);
}

/* ============================================================
   CONTACT SECTION
   ============================================================ */
.contact-section { background: var(--bg-primary); }
.contact-form-container { max-width: 600px; margin: 0 auto; }

.form-group { margin-bottom: 1.5rem; }
.form-group label { display: block; color: var(--text-secondary); margin-bottom: 0.5rem; font-size: 0.95rem; }

.form-group input,
.form-group textarea {
    width: 100%;
    padding: 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 1rem;
    transition: all 0.3s;
    font-family: inherit;
}

.form-group input:focus,
.form-group textarea:focus {
    outline: none;
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
}

[data-theme="light"] .form-group input:focus,
[data-theme="light"] .form-group textarea:focus {
    box-shadow: 0 0 0 3px rgba(79,70,229,0.1);
}

.form-group input::placeholder,
.form-group textarea::placeholder { color: var(--text-muted); }
.form-group textarea { min-height: 150px; resize: vertical; }

.submit-btn {
    width: 100%;
    padding: 1.125rem 2rem;
    background: var(--gradient);
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 1.0625rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    letter-spacing: 0.3px;
}

.submit-btn::before {
    content: "";
    position: absolute;
    top: 50%; left: 50%;
    width: 0; height: 0;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
}

.submit-btn:hover:not(:disabled)::before { width: 400px; height: 400px; }
.submit-btn:hover:not(:disabled) { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(99,102,241,0.4); }
.submit-btn:active:not(:disabled) { transform: translateY(-1px); }
.submit-btn:disabled { opacity: 0.7; cursor: not-allowed; transform: none !important; }
.submit-btn span { position: relative; z-index: 1; }

.form-message {
    margin-top: 1.5rem;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    text-align: center;
    display: none;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.6;
    animation: slideInMessage 0.4s ease-out;
}

@keyframes slideInMessage {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
}

.form-message.success {
    background: rgba(34,197,94,0.12);
    border: 2px solid rgba(34,197,94,0.35);
    color: #16a34a;
    display: block;
    box-shadow: 0 4px 12px rgba(34,197,94,0.15);
}

[data-theme="dark"] .form-message.success { color: #22c55e; }

.form-message.error {
    background: rgba(239,68,68,0.12);
    border: 2px solid rgba(239,68,68,0.35);
    color: #dc2626;
    display: block;
    box-shadow: 0 4px 12px rgba(239,68,68,0.15);
}

[data-theme="dark"] .form-message.error { color: #ef4444; }

/* ============================================================
   FOOTER
   ============================================================ */
.footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    padding: 2rem 0;
    text-align: center;
    color: var(--text-muted);
}

/* ============================================================
   LOADING / EMPTY STATE / SPINNER
   ============================================================ */
.loading {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-secondary);
    grid-column: 1 / -1;
}

.spinner {
    border: 3px solid var(--border-color);
    border-top: 3px solid var(--accent-primary);
    border-radius: 50%;
    width: 50px; height: 50px;
    animation: spin 1s linear infinite;
    margin: 0 auto 1rem;
}

@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

.empty-state { text-align: center; padding: 4rem 2rem; color: var(--text-muted); grid-column: 1 / -1; }
.empty-state h3 { font-size: 1.5rem; margin-bottom: 0.5rem; color: var(--text-secondary); }

@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ============================================================
   MODAL
   ============================================================ */
.post-view-modal {
    display: none;
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 9999;
}

.post-view-modal.active { display: flex; align-items: center; justify-content: center; }

.post-view-modal .modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.8);
    backdrop-filter: blur(5px);
}

[data-theme="light"] .post-view-modal .modal-overlay {
    background: rgba(0,0,0,0.55);
}

.post-view-modal .modal-container {
    position: relative;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    max-width: 900px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 24px 48px rgba(0,0,0,0.4);
    animation: modalSlideIn 0.3s ease-out;
}

[data-theme="light"] .post-view-modal .modal-container {
    box-shadow: 0 24px 48px rgba(0,0,0,0.12);
}

@keyframes modalSlideIn {
    from { opacity: 0; transform: translateY(20px) scale(0.95); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
}

.post-view-modal .modal-close {
    position: absolute;
    top: 1.25rem; right: 1.25rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    width: 45px; height: 45px;
    border-radius: 8px;
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    z-index: 10;
    line-height: 1;
}

.post-view-modal .modal-close:hover {
    background: #ef4444;
    color: #fff;
    border-color: #ef4444;
    transform: rotate(90deg);
}

.post-view-modal .modal-content { padding: 2rem; }

.post-view-modal .modal-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.post-view-modal .modal-header h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
}

.post-view-modal .modal-banner {
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 2rem;
    border: 1px solid var(--border-color);
    background: var(--bg-tertiary);
}

.post-view-modal .modal-banner img { width: 100%; height: 100%; object-fit: cover; }

.post-view-modal .modal-body p {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
}

.post-view-modal .modal-meta {
    color: var(--text-muted);
    font-size: 0.9375rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 2rem;
}

.post-view-modal .modal-gallery h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
}

.modal-gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
}

.modal-gallery-item {
    aspect-ratio: 16/9;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.3s ease;
    border: 1px solid var(--border-color);
    background: var(--bg-tertiary);
}

.modal-gallery-item:hover {
    transform: translateY(-4px);
    border-color: var(--accent-primary);
    box-shadow: 0 12px 24px rgba(99,102,241,0.2);
}

.modal-gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
.modal-gallery-item:hover img { transform: scale(1.05); }

.post-view-modal .modal-container::-webkit-scrollbar { width: 8px; }
.post-view-modal .modal-container::-webkit-scrollbar-track { background: var(--bg-primary); border-radius: 10px; }
.post-view-modal .modal-container::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 10px; }
.post-view-modal .modal-container::-webkit-scrollbar-thumb:hover { background: var(--accent-primary); }

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 1024px) {
    .portfolio-grid { grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); }
}

@media (max-width: 768px) {
    .hero-content { grid-template-columns: 1fr; text-align: center; }
    .hero-text h1 { font-size: 2rem; }
    .typing-container { justify-content: center; }
    .im-a, .typing-text { font-size: 1.3rem; }
    .hero-image { order: -1; }
    .hero-image img { max-width: 300px; }
    .nav-links { gap: 1rem; font-size: 0.9rem; }
    .portfolio-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .section-title { font-size: 2rem; }
    section { padding: 4rem 0; }
    .container { padding: 0 1rem; }
    .view-all-container .btn { padding: 1rem 2rem; font-size: 1rem; width: 100%; max-width: 300px; }
    .modal-container { width: 95%; max-height: 95vh; }
    .post-view-modal .modal-content { padding: 1.5rem; }
    .post-view-modal .modal-header h2 { font-size: 1.5rem; }
    .modal-gallery-grid { grid-template-columns: 1fr; }
    .post-view-modal .modal-close { width: 40px; height: 40px; font-size: 1.25rem; }
    .highlights-grid { grid-template-columns: 1fr; }
}

@media (max-width: 480px) {
    .view-all-container { padding: 0 1rem; }
}